# --- Telegram --------------------------------------------------------------
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Chat_id, куда слать уведомления о новых заявках (личка или группа).
# Как узнать: напиши боту /myid — он вернёт chat_id этого чата.
# Для группы: добавь бота в группу и отправь там /myid (id группы отрицательный).
MARKETING_CHAT_ID=

# Максимум файлов, которые можно приложить к одной заявке
MAX_ATTACHMENTS=10

# --- Microsoft Graph / Planner ---------------------------------------------
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
PLANNER_PLAN_ID=
# ID bucket'а, куда падают заявки. Если пусто — bucket ищется по PLANNER_BUCKET_NAME,
# и только если и по имени не нашёлся — берётся первый bucket плана.
PLANNER_BUCKET_ID=
PLANNER_BUCKET_NAME=📥 Новые заявки
# false — заявки не уходят в Planner, только в jsonl-лог (режим локальной проверки)
PLANNER_ENABLED=true

# --- LLM (нормализация описания) -------------------------------------------
LLM_BASE_URL=http://<llm-host>:8000/v3
LLM_MODEL=OpenVINO/Qwen3-14B-int8-ov
LLM_API_KEY=not-needed
LLM_TIMEOUT=120
LLM_NORMALIZE=true

# --- Прочее ----------------------------------------------------------------
# --- HTTP API (статистика для веб-панели) ----------------------------------
API_PORT=8080
# Bearer-токен для веб-панели. Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Пусто — API вернёт 401 на все запросы, кроме /health.
API_TOKEN=
# Как часто фоновая задача обновляет статусы заявок из Planner, секунд
STATUS_REFRESH_SECONDS=90

# Внешняя docker-сеть платформы, к которой подключается контейнер
PLATFORM_NETWORK=platform_net
# Каталог для jsonl-логов заявок внутри контейнера
DATA_DIR=/data
# SQLite со связью пользователь→заявки (для раздела «Мои заявки»).
# Должен лежать на volume, иначе история потеряется при пересборке контейнера.
REQUESTS_DB_PATH=/data/requests.db
LOG_LEVEL=INFO
